{
  "redirects": [
    {
      "source": "/visita/:path*",
      "destination": "https://igreja-gerando-vencedores.ekthoschurch.com/visita/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "ekthos-platform.vercel.app" }]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
